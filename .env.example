# ========================================
# Swater Blog 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改配置
# ========================================

# ========================================
# 数据库配置(MySQL)
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# ========================================
# Redis 缓存配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ========================================
# RabbitMQ 消息队列配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VHOST=/

# ========================================
# Elasticsearch 搜索引擎配置（当前默认禁用）
# ========================================
ES_URIS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# ========================================
# 文件存储配置
# ========================================
# 存储类型: local/oss/qiniu
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=/app/uploads
FILE_STORAGE_LOCAL_URL_PREFIX=/uploads

# 阿里云 OSS 配置（当 FILE_STORAGE_TYPE=oss 时使用）
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_DOMAIN=

# 七牛云配置（当 FILE_STORAGE_TYPE=qiniu 时使用）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# ========================================
# 邮件服务配置
# ========================================
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=change_me_mail_app_password
MAIL_FROM_NAME=Swater Blog

# ========================================
# 第三方服务配置
# ========================================
# 高德地图 API Key（用于IP定位）
AMAP_KEY=your_amap_key

# 百度地图 API Key（备选方案）
BAIDU_AK=

# IP2Location 数据库路径（离线IP定位）
IP2LOCATION_DB_PATH=

# ========================================
# 安全配置
# ========================================
# JWT 密钥（生产环境请使用强密码）
JWT_SECRET_KEY=change_me_jwt_secret

# 邮箱验证会话密钥
AUTH_EMAIL_SESSION_SECRET=change_me_email_session_secret

# ========================================
# 功能开关配置
# ========================================
# 搜索引擎类型: database/elasticsearch
SEARCH_TYPE=database

# 消息队列类型: rabbitmq/memory
MQ_TYPE=rabbitmq

# 位置服务类型: amap/baidu/ip2location
LOCATION_TYPE=amap

# 是否启用 Swagger API 文档
SWAGGER_ENABLED=false

# 是否启用 IP 黑名单
IP_BLACKLIST_ENABLED=false
IP_BLACKLIST=

# ========================================
# 应用服务配置
# ========================================
# Spring Boot 配置文件
SPRING_PROFILES_ACTIVE=docker

# 后端服务端口
SERVER_PORT=8888

# 监控端口
MANAGEMENT_PORT=8081

# ========================================
# Docker 容器配置
# ========================================
# 应用版本
APP_VERSION=1.0.0

# JVM 内存配置
JVM_XMS=512m
JVM_XMX=1024m

# Java 运行参数
JAVA_OPTS=-XX:+UseG1GC -XX:+UseContainerSupport

# 是否启用调试模式
ENABLE_DEBUG=false
DEBUG_PORT=5005

# 是否启用 JMX 监控
ENABLE_JMX=false
JMX_PORT=9999

# 是否启用 GC 日志
ENABLE_GC_LOG=false

# ========================================
# 开发环境配置
# ========================================
# 是否跳过环境变量检查
SKIP_ENV_CHECK=false

# 是否跳过依赖服务等待
SKIP_WAIT=false

# 是否跳过预启动检查
SKIP_CHECKS=false

# 是否等待数据库
WAIT_FOR_DB=true

# 是否等待 Redis
WAIT_FOR_REDIS=true

# 是否等待 RabbitMQ
WAIT_FOR_RABBITMQ=true

# 是否等待 Elasticsearch
WAIT_FOR_ES=false

# ========================================
# 日志配置
# ========================================
# 日志级别
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BLOG=INFO

# 日志文件路径
LOGGING_FILE_NAME=logs/application.log

# ========================================
# 时区配置
# ========================================
TZ=Asia/Shanghai


# ========================================
# Nginx 配置
# ========================================
COMPOSE_PROFILES=http
ALL_DOMAINS=admin.local,web.local
ACME_EMAIL=admin@example.com
NGINX_ADMIN_DOMAIN=admin.local
NGINX_WEB_DOMAIN=web.local

# ========================================
# Docker 构建方式（前台/后台）
# ========================================
# 使用本地构建产物（不在镜像内编译）时，设置为 Dockerfile.local
# BLOG_SERVICE_DOCKERFILE=Dockerfile.local
# BLOG_ADMIN_DOCKERFILE=Dockerfile.local
# BLOG_WEB_DOCKERFILE=Dockerfile.local


