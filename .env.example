# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=your_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# Elasticsearch 配置（当前默认禁用）
ES_URIS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# 文件存储配置
# local/oss/qiniu
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=/var/blog/uploads
# 如果使用 OSS
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_DOMAIN=
# 如果使用七牛
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_password
MAIL_FROM_NAME=Swater Blog

# 第三方服务配置
AMAP_KEY=your_amap_key
BAIDU_AK=
IP2LOCATION_DB_PATH=

# JWT / 会话密钥
JWT_SECRET_KEY=your_jwt_secret_key
AUTH_EMAIL_SESSION_SECRET=change-me-in-production

# 功能开关
# database/elasticsearch
SEARCH_TYPE=database
# rabbitmq/memory
MQ_TYPE=rabbitmq
# amap/baidu/ip2location
LOCATION_TYPE=amap
SWAGGER_ENABLED=false
IP_BLACKLIST_ENABLED=false
IP_BLACKLIST=

# 应用配置
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8888
MANAGEMENT_PORT=8081
