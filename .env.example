# ========================================
# Swater Blog 环境变量配置示例
# 复制此文件为 .env，并只填写外部连接、端口、账号、密码、邮箱、域名、Token、Key 等敏感或环境相关值。
# ========================================

# ========================================
# Docker Compose 入口
# ========================================
COMPOSE_PROFILES=http

# ========================================
# 服务端口
# ========================================
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8888
BLOG_SERVICE_PUBLISHED_PORT=8888
BLOG_ADMIN_PUBLISHED_PORT=3001
BLOG_WEB_PUBLISHED_PORT=3002
NGINX_HTTP_PUBLISHED_PORT=80
NGINX_HTTPS_PUBLISHED_PORT=443
ELASTICSEARCH_HTTP_PUBLISHED_PORT=9200
ELASTICSEARCH_TRANSPORT_PUBLISHED_PORT=9300

# ========================================
# 数据库配置(MySQL)
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# ========================================
# Nginx / HTTPS 域名和邮箱
# ========================================
ALL_DOMAINS=admin.local,web.local
ACME_EMAIL=admin@example.com
NGINX_ADMIN_DOMAIN=admin.local
NGINX_WEB_DOMAIN=web.local


# ========================================
# Redis 缓存配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PUBLISHED_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ========================================
# RabbitMQ 消息队列配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PUBLISHED_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VHOST=/

# ========================================
# 监控栈端口
# ========================================
PROMETHEUS_PUBLISHED_PORT=9090
GRAFANA_PUBLISHED_PORT=3000
ALERTMANAGER_PUBLISHED_PORT=9093
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093
NODE_EXPORTER_PUBLISHED_PORT=9100
MYSQL_EXPORTER_PUBLISHED_PORT=9104
REDIS_EXPORTER_PUBLISHED_PORT=9121
