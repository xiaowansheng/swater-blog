# ========================================
# Swater Blog 环境变量配置示例
# 复制此文件为 .env，并只填写外部连接、端口、账号、密码、邮箱、域名、Token、Key 等敏感或环境相关值。
# ========================================

# ========================================
# Docker Compose 入口
# ========================================
COMPOSE_PROFILES=http

# ========================================
# 数据库配置(MySQL)
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# ========================================
# Redis 缓存配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PUBLISHED_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ========================================
# RabbitMQ 消息队列配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VHOST=/

# ========================================
# 文件存储地址与凭证
# ========================================
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=/app/uploads
FILE_STORAGE_LOCAL_URL_PREFIX=/uploads

OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_DOMAIN=

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# ========================================
# 邮件服务配置
# ========================================
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=change_me_mail_app_password
MAIL_FROM_NAME=Swater Blog

# ========================================
# 第三方服务 Key / 路径
# ========================================
LOCATION_TYPE=amap
AMAP_KEY=your_amap_key
BAIDU_AK=
IP2LOCATION_DB_PATH=

# ========================================
# 安全凭证
# ========================================
JWT_SECRET_KEY=change_me_jwt_secret
AUTH_EMAIL_SESSION_SECRET=change_me_email_session_secret
REVALIDATE_TOKEN=
REVALIDATE_URL=http://host.docker.internal:3001

# ========================================
# 管理员初始化
# 首次空库启动时会自动创建该管理员；用户已存在时不会重置密码。
# 生产环境必须设置强密码，不要使用示例占位值。
# ========================================
BLOG_BOOTSTRAP_ADMIN_USERNAME=admin
BLOG_BOOTSTRAP_ADMIN_PASSWORD=
BLOG_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ========================================
# 服务端口
# ========================================
SERVER_PORT=8888
BLOG_ADMIN_PUBLISHED_PORT=3001
BLOG_WEB_PUBLISHED_PORT=3002

# ========================================
# Nginx / HTTPS 域名和邮箱
# ========================================
ALL_DOMAINS=admin.local,web.local
ACME_EMAIL=admin@example.com
NGINX_ADMIN_DOMAIN=admin.local
NGINX_WEB_DOMAIN=web.local

# ========================================
# 管理后台前端地址
# ========================================
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_UPLOAD_URL=/api/upload
VITE_UPLOAD_RESOURCE_PREFIX=/uploads
VITE_BLOG_URL=http://localhost
VITE_GITHUB_URL=https://github.com/xiaowansheng/swater-blog

# ========================================
# 博客前台地址
# ========================================
NEXT_PUBLIC_API_BASE_URL=/
SERVER_API_BASE_URL=http://blog-service:8888
NEXT_PUBLIC_UPLOAD_RESOURCE_PREFIX=/uploads
NEXT_PUBLIC_SITE_URL=http://localhost
