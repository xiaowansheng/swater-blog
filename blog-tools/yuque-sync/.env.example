# 数据库配置
DATABASE_URL="file:./data/yuque-sync.db"

# 语雀配置（可选，也可以在Web界面配置）
YUQUE_TOKEN=""
YUQUE_BASE_URL="https://www.yuque.com/api/v2"
YUQUE_NAMESPACE=""

# 博客数据库配置（可选，也可以在Web界面配置）
BLOG_TYPE="mysql"
BLOG_HOST="localhost"
BLOG_PORT=3306
BLOG_DATABASE="blog"
BLOG_USERNAME="root"
BLOG_PASSWORD=""

# 应用配置
NODE_ENV=development
