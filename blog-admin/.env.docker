# ========================================
# Blog Admin Docker 环境变量配置
# ========================================

# Admin 端口
ADMIN_PORT=3001

# Nginx 端口（如果使用额外的 nginx 代理层）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# API 后端地址（需要在构建前设置到 .env.production）
VITE_API_BASE_URL=http://localhost:8888

# 其他环境变量
NODE_ENV=production
