# 开发环境配置
VITE_API_BASE_URL=http://localhost:8888/api
VITE_WS_BASE_URL=ws://localhost:8888

# 开发模式
NODE_ENV=development
VITE_APP_ENV=development

# 调试配置
VITE_DEBUG=true
VITE_MOCK_ENABLED=false

# 本地存储前缀
VITE_STORAGE_PREFIX=blog_admin_dev_

# 上传配置
VITE_UPLOAD_URL=http://localhost:8888/api/upload
VITE_UPLOAD_RESOURCE_PREFIX=http://localhost:8888/uploads
VITE_UPLOAD_MAX_SIZE=10485760

# 其他配置
VITE_APP_TITLE=博客管理系统 - 开发环境
VITE_APP_VERSION=1.0.0-dev

