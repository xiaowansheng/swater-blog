# 本地环境配置 - 使用相对路径
VITE_API_BASE_URL=/api
# VITE_WS_BASE_URL 留空，将自动根据当前域名生成
# 开发时如需指定：VITE_WS_BASE_URL=ws://localhost:8888
# 生产时会自动使用：ws://yourdomain.com 或 wss://yourdomain.com

# 生产模式
NODE_ENV=production
VITE_APP_ENV=production

# 调试配置
VITE_DEBUG=false
VITE_MOCK_ENABLED=false

# 本地存储前缀
VITE_STORAGE_PREFIX=blog_admin_

# 上传配置
VITE_UPLOAD_URL=/api/upload
VITE_UPLOAD_RESOURCE_PREFIX=/uploads
VITE_UPLOAD_MAX_SIZE=10485760

# 其他配置
VITE_APP_TITLE=博客管理系统
VITE_APP_VERSION=1.0.0